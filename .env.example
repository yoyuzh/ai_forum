# Environment variables consumed by the ai-forum backend config loader.
# Copy to .env and fill in real values. All secrets MUST come from the
# environment, never from committed config files (architecture §14.1).
#
# Generate INTERNAL_API_TOKEN and JWT_SECRET with:
#   openssl rand -hex 32

# --- Server ---
SERVER_PORT=8080
SERVER_MODE=debug

# --- MySQL (strong-consistency source of truth) ---
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USERNAME=root
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=ai_forum

# --- Redis (cache/counters/queue-infra) ---
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# --- RabbitMQ (domain event bus) ---
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- JWT (always required, even in debug) ---
JWT_SECRET=change-me
JWT_EXPIRE_HOURS=168

# --- Internal API token (worker→api-server, always required) ---
# Generate with: openssl rand -hex 32
INTERNAL_API_TOKEN=change-me

# --- AI provider ---
AI_PROVIDER=openai
AI_BASE_URL=https://api.openai.com
AI_MODEL=gpt-4o-mini
AI_API_KEY=change-me
AI_MAX_CONCURRENCY=4
AI_REQUEST_PER_SECOND=2
AI_BURST=2

# --- Logging ---
LOG_LEVEL=info
LOG_ENCODING=json
